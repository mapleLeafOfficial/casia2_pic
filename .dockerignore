# Git
.git
.gitignore

# Python 缓存
__pycache__
*.pyc
*.pyo
*.egg-info
.eggs

# 虚拟环境
.venv
venv
env

# IDE 配置
.vscode
.idea
*.swp
*.swo

# 数据集（太大，不打包进镜像）
data/raw/*
!data/raw/.gitkeep

# 模型检查点（太大）
models/checkpoints/*
!models/checkpoints/.gitkeep

# 日志与输出
logs/*
outputs/*

# OpenSpec 工作区
openspec/
.agent/
.claude/
.codex/

# 系统文件
.DS_Store
Thumbs.db
